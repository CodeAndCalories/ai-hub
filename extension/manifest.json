{
  "manifest_version": 3,
  "name": "AI Hub",
  "version": "5.0.0",
  "description": "Chat with ChatGPT, Claude, Gemini, and Grok in one popup.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Hub"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["tabs", "storage"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://grok.com/*",
    "https://api.openai.com/*",
    "https://api.anthropic.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.x.ai/*",
    "http://localhost/*",
    "https://memstore.dev/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
